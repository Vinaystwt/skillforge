{
  "name": "skillforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @skillforge/web dev",
    "dev:api": "pnpm --filter @skillforge/api dev",
    "dev:contracts": "pnpm --filter @skillforge/contracts hardhat node",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format"
  }
}

